digraph readme_outputs {
  graph [
    bgcolor="transparent",
    rankdir=LR,
    splines=spline,
    nodesep=0.34,
    ranksep=0.50,
    pad=0.12,
    margin=0.04,
    outputorder=edgesfirst
  ];

  node [
    shape=rect,
    style="rounded,filled",
    fontname="Liberation Sans",
    fontsize=12,
    color="#cbd5e1",
    penwidth=1.3,
    margin="0.11,0.08"
  ];

  edge [color="#94a3b8", arrowsize=0.65, penwidth=1.0];

  run [label="Optimization run", fillcolor="#0f172a", fontcolor="#ffffff", color="#334155"];
  json [label="optimization_result.json\nBest coordinate", fillcolor="#eff6ff", color="#60a5fa"];
  csv [label="candidate_metrics.csv\nEvery AP scored", fillcolor="#fef3c7", color="#fbbf24"];
  heatmap [label="worst_case_path_loss_heatmap.png\nObjective surface", fillcolor="#fee2e2", color="#f87171"];
  layout [label="topdown_layout.png\nMesh, receivers, APs", fillcolor="#dcfce7", color="#4ade80"];

  run -> json;
  run -> csv;
  run -> heatmap;
  run -> layout;
}
